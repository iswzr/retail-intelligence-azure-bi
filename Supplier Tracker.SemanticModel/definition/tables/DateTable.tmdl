	partition DateTable = calculated
		mode: import
		source =
				
				VAR MinYear = YEAR(MIN(RetailSales[TransactionDate]))
				VAR MaxYear = YEAR(MAX(RetailSales[TransactionDate]))
				RETURN
				ADDCOLUMNS (
				    CALENDAR ( DATE(MinYear, 1, 1), DATE(MaxYear, 12, 31) ),
				    "Year", YEAR([Date]),
				    "Quarter", "Q" & FORMAT([Date], "Q"),
				    "Month Number", MONTH([Date]),
				    "Month Name", FORMAT([Date], "MMMM"),
				    "Month Short", FORMAT([Date], "MMM"),
				    "Year Month", FORMAT([Date], "MMM YYYY"),
				    "Year Month Sort", YEAR([Date]) * 100 + MONTH([Date]),
				    "Day of Month", DAY([Date]),
				    "Day of Week Number", WEEKDAY([Date], 2), -- 2 sets Monday as Day 1
				    "Day Name", FORMAT([Date], "dddd"),
				    "Day Short", FORMAT([Date], "ddd")
				)

	annotation PBI_Id = 7f7957356ea745d7b7a99ba90e514512

