{
    "$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "factoryName": {
            "type": "string",
            "metadata": "Data Factory name",
            "defaultValue": "retail-cdf"
        },
        "dataFactory_location": {
            "type": "string",
            "defaultValue": "uaenorth"
        },
        "dataFactory_identity_type": {
            "type": "string",
            "defaultValue": "SystemAssigned"
        }
    },
    "variables": {
        "factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
    },
    "resources": [
        {
            "name": "[parameters('factoryName')]",
            "type": "Microsoft.DataFactory/factories",
            "apiVersion": "2018-06-01",
            "properties": {
                "trustModeClaimForMi": {
                    "value": "Enabled",
                    "editable": true
                }
            },
            "dependsOn": [],
            "location": "[parameters('dataFactory_location')]",
            "identity": {
                "type": "[parameters('dataFactory_identity_type')]",
                "principalId": "11e83459-7b87-4557-b5f7-f1c5f14b29f9",
                "tenantId": "463e23a2-257e-4fec-8d73-fca21db99f7c"
            }
        }
    ]
}