{
    "$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "factoryName": {
            "type": "string",
            "metadata": "Data Factory name",
            "defaultValue": "retail-cdf"
        },
        "LinkedService_ADLS_accountKey": {
            "type": "secureString",
            "metadata": "Secure string for 'accountKey' of 'LinkedService_ADLS'"
        },
        "LinkedService_SQL_password": {
            "type": "secureString",
            "metadata": "Secure string for 'password' of 'LinkedService_SQL'"
        },
        "LinkedService_ADLS_properties_typeProperties_url": {
            "type": "string",
            "defaultValue": "https://retaildata55.dfs.core.windows.net/"
        },
        "LinkedService_SQL_properties_typeProperties_server": {
            "type": "string",
            "defaultValue": "retail-srv.database.windows.net"
        },
        "LinkedService_SQL_properties_typeProperties_database": {
            "type": "string",
            "defaultValue": "retail-sales-db"
        },
        "LinkedService_SQL_properties_typeProperties_userName": {
            "type": "string",
            "defaultValue": "retailadmin"
        },
        "containerUri": {
            "type": "string",
            "metadata": "URI to storage account containing linked ARM templates"
        },
        "containerSasToken": {
            "type": "string",
            "metadata": "Sas token to storage account containing linked ARM templates"
        }
    },
    "variables": {
        "factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
    },
    "resources": [
        {
            "name": "retail-cdf_ArmTemplate_0",
            "type": "Microsoft.Resources/deployments",
            "apiVersion": "2024-03-01",
            "properties": {
                "mode": "incremental",
                "templateLink": {
                    "uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
                    "contentVersion": "1.0.0.0"
                },
                "parameters": {
                    "factoryName": {
                        "value": "[parameters('factoryName')]"
                    },
                    "LinkedService_ADLS_accountKey": {
                        "value": "[parameters('LinkedService_ADLS_accountKey')]"
                    },
                    "LinkedService_SQL_password": {
                        "value": "[parameters('LinkedService_SQL_password')]"
                    },
                    "LinkedService_ADLS_properties_typeProperties_url": {
                        "value": "[parameters('LinkedService_ADLS_properties_typeProperties_url')]"
                    },
                    "LinkedService_SQL_properties_typeProperties_server": {
                        "value": "[parameters('LinkedService_SQL_properties_typeProperties_server')]"
                    },
                    "LinkedService_SQL_properties_typeProperties_database": {
                        "value": "[parameters('LinkedService_SQL_properties_typeProperties_database')]"
                    },
                    "LinkedService_SQL_properties_typeProperties_userName": {
                        "value": "[parameters('LinkedService_SQL_properties_typeProperties_userName')]"
                    }
                }
            },
            "dependsOn": []
        }
    ]
}